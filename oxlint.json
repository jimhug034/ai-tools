{
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "warn",
    "restriction": "off"
  },
  "ignore": [
    "node_modules",
    ".next",
    "dist",
    "build",
    "coverage",
    "*.config.js",
    "*.config.ts"
  ],
  "targets": {
    "javascript": "ES2022",
    "typescript": "ES2022"
  }
}
